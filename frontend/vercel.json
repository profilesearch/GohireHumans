{
  "buildCommand": null,
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "gohirehumans.com"}],
      "destination": "https://www.gohirehumans.com/:path*",
      "permanent": true
    },
    { "source": "/fiverr-alternatives", "destination": "/blog/alternatives-to-fiverr.html", "permanent": true },
    { "source": "/fiver-alternatives", "destination": "/blog/alternatives-to-fiverr.html", "permanent": true },
    { "source": "/upwork-alternatives", "destination": "/blog/alternatives-to-upwork.html", "permanent": true },
    { "source": "/toptal-alternatives", "destination": "/blog/alternatives-to-toptal.html", "permanent": true },
    { "source": "/freelancer-alternatives", "destination": "/blog/alternatives-to-freelancer.html", "permanent": true },
    { "source": "/vs-fiverr", "destination": "/vs/fiverr.html", "permanent": true },
    { "source": "/vs-upwork", "destination": "/vs/upwork.html", "permanent": true },
    { "source": "/vs-toptal", "destination": "/vs/toptal.html", "permanent": true },
    { "source": "/vs-freelancer", "destination": "/vs/freelancer.html", "permanent": true },
    { "source": "/fee-calculator", "destination": "/tools/freelance-fee-calculator.html", "permanent": true },
    { "source": "/calculator", "destination": "/tools/freelance-fee-calculator.html", "permanent": true },
    { "source": "/quiz", "destination": "/tools/are-you-overpaying.html", "permanent": true },
    { "source": "/are-you-overpaying", "destination": "/tools/are-you-overpaying.html", "permanent": true },
    { "source": "/hire", "destination": "/hire/", "permanent": true },
    { "source": "/categories", "destination": "/categories/", "permanent": true },
    { "source": "/tools", "destination": "/tools/", "permanent": true },
    { "source": "/vs", "destination": "/vs/", "permanent": true },
    { "source": "/blog", "destination": "/blog/", "permanent": true },
    { "source": "/sitemap", "destination": "/sitemap.xml", "permanent": true },
    { "source": "/feed", "destination": "/feed.xml", "permanent": true },
    { "source": "/rss", "destination": "/feed.xml", "permanent": true },
    { "source": "/atom", "destination": "/atom.xml", "permanent": true },
    { "source": "/security", "destination": "/.well-known/security.txt", "permanent": true },
    { "source": "/contact", "destination": "/about.html", "permanent": false },
    { "source": "/help", "destination": "/faq.html", "permanent": false },
    { "source": "/support", "destination": "/faq.html", "permanent": false },
    { "source": "/api", "destination": "/api-docs.html", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/((?!api/)(?!.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "0" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), payment=(self \"https://js.stripe.com\" \"https://checkout.stripe.com\"), interest-cohort=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com/gsi/ https://www.googletagmanager.com https://www.google-analytics.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com/gsi/; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://gohirehumans-production.up.railway.app https://accounts.google.com/ https://oauth2.googleapis.com/ https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://stats.g.doubleclick.net https://api.stripe.com; frame-src https://accounts.google.com/gsi/ https://js.stripe.com https://hooks.stripe.com; form-action 'self' https://checkout.stripe.com; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; upgrade-insecure-requests;" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:js|css|woff2?|png|jpg|jpeg|svg|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
      ]
    }
  ]
}
