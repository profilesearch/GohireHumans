# GoHireHumans API — Environment Variables
# Copy this file to .env and fill in your values

# Port (Railway sets this automatically)
PORT=8080

# Flask debug mode (set to false in production)
FLASK_DEBUG=false

# Database path (SQLite file location)
DATABASE_PATH=agentwork.db

# Secret for the /seed endpoint (required to enable seeding)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SEED_SECRET=

# CORS allowed origins (comma-separated, use * for development)
ALLOWED_ORIGINS=*

# Stripe integration (leave empty to use simulated payments)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URL (for Stripe redirect URLs)
FRONTEND_URL=https://gohirehumans.com

# Google OAuth (leave empty to use simulated OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
