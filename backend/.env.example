# GoHireHumans API — Environment Variables
# Copy this file to .env and fill in your values

# Port (Railway sets this automatically)
PORT=8080

# Flask debug mode (set to false in production)
FLASK_DEBUG=false

# Database path (SQLite file location).
# In production set this to /app/data/agentwork.db so it lives on the Railway volume.
DATABASE_PATH=agentwork.db

# Secret for the /seed endpoint (required to enable seeding).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable the /seed endpoint entirely (recommended for production
# after the initial seed).
SEED_SECRET=

# CORS allowed origins (comma-separated).
# IMPORTANT: do NOT use "*" in production — server.py refuses wildcard with credentials.
# For local dev, point at your frontend dev server.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Stripe integration (leave empty to use simulated payments).
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URL (for Stripe redirect URLs)
FRONTEND_URL=https://www.gohirehumans.com

# Google OAuth (leave empty to use simulated OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (transactional) — required for password reset & email verification ──
# Use Postmark, Resend, AWS SES, or SendGrid.
EMAIL_FROM=noreply@gohirehumans.com
EMAIL_PROVIDER=postmark
EMAIL_API_KEY=

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json
